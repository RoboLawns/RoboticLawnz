{
  "name": "zippylawnz",
  "version": "0.1.0",
  "private": true,
  "description": "ZippyLawnz — customer-facing web app.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "build:web": "pnpm --filter @zippylawnz/web build",
    "start:web": "node apps/web/server.js"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "typescript": "^5.6.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
