# =====================================================================
# Robotic Lawnz — environment variables
# Copy to .env (root, for tooling) or apps/web/.env.local & apps/api/.env
# =====================================================================

# --- Shared ---
APP_ENV=dev                            # dev | staging | prod
PUBLIC_APP_URL=http://localhost:3000

# --- Database (Postgres 16 + PostGIS) ---
DATABASE_URL=postgresql+psycopg://roboticlawnz:roboticlawnz@localhost:5432/roboticlawnz
SYNC_DATABASE_URL=postgresql+psycopg://roboticlawnz:roboticlawnz@localhost:5432/roboticlawnz

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# --- Maps ---
# Mapbox public token — enables the interactive satellite lawn-drawing map in Step 2.
# Get one free at https://account.mapbox.com/  (public token, safe to expose in browser)
# Without this, the map step falls back to a manual sq-ft text input.
NEXT_PUBLIC_MAPBOX_TOKEN=
# Google Places API key — powers the address autocomplete in Step 1.
# Create a key at https://console.cloud.google.com/apis/credentials
# Restrict it to the Places API and your production domain for security.
NEXT_PUBLIC_GOOGLE_PLACES_KEY=
# Google Maps server-side key — used for Geocoding and Static Maps proxy.
# Keep this key server-only (never prefix with NEXT_PUBLIC_).
GOOGLE_MAPS_API_KEY=

# --- ML inference (Replicate) ---
REPLICATE_API_TOKEN=
SAM2_MODEL_VERSION=
GRASS_CLASSIFIER_MODEL_VERSION=

# --- Email (Resend) ---
RESEND_API_KEY=
SALES_INBOX_EMAIL=sales@zippylawnz.com
FROM_EMAIL=hello@roboticlawnz.com

# --- Storage (Cloudflare R2, S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=roboticlawnz-uploads
R2_PUBLIC_BASE_URL=

# --- Observability ---
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
SESSION_COOKIE_SECRET=replace-me-with-32+-bytes-of-random

# Base URL the frontend uses to call the API.
#   Local dev (separate servers): http://localhost:8000/api/v1
#   Combined Docker deploy:       /api/v1  (relative — Next.js proxies internally)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Internal FastAPI URL used by Next.js rewrites in the combined Docker image.
# Set only for the single-container deployment; leave unset for local dev.
API_INTERNAL_URL=
