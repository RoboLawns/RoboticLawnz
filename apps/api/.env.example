# ── Runtime ───────────────────────────────────────────────────────────────────
APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://roboticlawnz:roboticlawnz@localhost:5432/roboticlawnz

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Clerk (https://dashboard.clerk.com) ───────────────────────────────────────
CLERK_SECRET_KEY=
# Optional — override if you want to point at a mock JWKS in tests
# CLERK_JWKS_URL=https://api.clerk.com/v1/jwks
CLERK_WEBHOOK_SECRET=

# ── Sessions / signed cookies ─────────────────────────────────────────────────
SESSION_COOKIE_SECRET=change-me-in-production

# ── Maps ──────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
SALES_INBOX_EMAIL=sales@zippylawnz.com
FROM_EMAIL=hello@roboticlawnz.com

# ── Storage (Cloudflare R2) ────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=roboticlawnz-uploads
R2_PUBLIC_BASE_URL=

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
